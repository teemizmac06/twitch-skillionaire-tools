# ── Telegram ──────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Any random secret string — used to verify webhook requests
# Generate one: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow everyone
# Get your ID: message @userinfobot
TELEGRAM_ALLOWED_USERS=

# ── Your Vercel App URL ────────────────────────
# The deployed URL of your Twitch Audit Pro Vercel project
APP_URL=https://your-project.vercel.app

# ── Twitch API ────────────────────────────────
# From https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=wck0uw2mywx841acjavyzpcay6yupg
TWITCH_CLIENT_SECRET=nodd91qd27x5njgk6fq4kh8w6osqhy

# ── Optional ──────────────────────────────────
LOG_LEVEL=info
