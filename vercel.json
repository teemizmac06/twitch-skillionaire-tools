{
  "version": 2,
  "regions": ["iad1"],
  "functions": {
    "api/telegram/webhook.js": { "maxDuration": 10,  "memory": 256  },
    "api/analyze/index.js":    { "maxDuration": 300, "memory": 3008 },
    "api/analyze/screenshots.js": { "maxDuration": 300, "memory": 3008 }
  },
  "routes": [
    { "src": "/api/telegram/webhook",      "dest": "/api/telegram/webhook.js" },
    { "src": "/api/analyze",               "dest": "/api/analyze/index.js" },
    { "src": "/api/analyze/screenshots",   "dest": "/api/analyze/screenshots.js" },
    { "src": "/api/health",                "dest": "/api/health.js" }
  ]
}
